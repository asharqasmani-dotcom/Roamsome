<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_primary }}">
    <link rel="canonical" href="{{ canonical_url }}">

    {% if settings.favicon != blank %}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 64, height: 64 }}">
    {% endif %}

    {% if settings.heading_font %}
      {{ settings.heading_font | font_face: font_display: 'swap' }}
    {% endif %}
    {% if settings.body_font %}
      {{ settings.body_font | font_face: font_display: 'swap' }}
    {% endif %}

    <title>
      {{ page_title }}
      {% if current_tags %} &ndash; tagged {{ current_tags | join: ', ' }}{% endif %}
      {% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
      {% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    <script>
      // Defensive guards installed BEFORE Shopify's content_for_header so any
      // app pixel / subscription script that tries to wipe the storefront is
      // intercepted. Confirmed culprit on this store: the Seal Subscriptions
      // app sets document.body.innerHTML = "0" after load.
      (function () {
        var nativeWrite = document.write.bind(document);
        var nativeWriteln = document.writeln ? document.writeln.bind(document) : null;
        var nativeOpen = document.open.bind(document);

        function appendLateWrite(html) {
          if (!document.body) return;
          var template = document.createElement('template');
          template.innerHTML = html;
          Array.prototype.slice.call(template.content.querySelectorAll('script')).forEach(function (oldScript) {
            var replacement = document.createElement('script');
            Array.prototype.slice.call(oldScript.attributes).forEach(function (attribute) {
              replacement.setAttribute(attribute.name, attribute.value);
            });
            if (oldScript.textContent) replacement.textContent = oldScript.textContent;
            oldScript.parentNode.replaceChild(replacement, oldScript);
          });
          document.body.appendChild(template.content);
        }

        function safeWrite() {
          var html = Array.prototype.join.call(arguments, '');
          if (document.readyState === 'loading') {
            nativeWrite(html);
            return;
          }
          var trimmed = String(html || '').trim();
          if (!trimmed || trimmed === '0') {
            console.warn('Blocked late document.write payload:', trimmed);
            return;
          }
          try { appendLateWrite(trimmed); } catch (error) {
            console.warn('Late document.write interception failed.', error);
          }
        }

        document.write = safeWrite;
        if (nativeWriteln) {
          document.writeln = function () {
            safeWrite(Array.prototype.join.call(arguments, '') + '\n');
          };
        }
        document.open = function () {
          if (document.readyState === 'loading') {
            return nativeOpen.apply(document, arguments);
          }
          console.warn('Blocked late document.open() call.');
          return document;
        };

        function looksLikeWipe(value) {
          var t = String(value == null ? '' : value).trim();
          return !t || t === '0' || t.length < 8;
        }

        var elDesc = Object.getOwnPropertyDescriptor(Element.prototype, 'innerHTML');
        if (elDesc && elDesc.set) {
          var origSetInner = elDesc.set;
          var origGetInner = elDesc.get;
          Object.defineProperty(Element.prototype, 'innerHTML', {
            configurable: true,
            enumerable: elDesc.enumerable,
            get: function () { return origGetInner.call(this); },
            set: function (v) {
              if (this === document.body && document.readyState !== 'loading' && looksLikeWipe(v)) {
                console.warn('Blocked body.innerHTML wipe payload:', JSON.stringify(String(v).slice(0, 60)));
                return;
              }
              return origSetInner.call(this, v);
            }
          });
        }

        var nodeTextDesc = Object.getOwnPropertyDescriptor(Node.prototype, 'textContent');
        if (nodeTextDesc && nodeTextDesc.set) {
          var origSetText = nodeTextDesc.set;
          var origGetText = nodeTextDesc.get;
          Object.defineProperty(Node.prototype, 'textContent', {
            configurable: true,
            enumerable: nodeTextDesc.enumerable,
            get: function () { return origGetText.call(this); },
            set: function (v) {
              if (this === document.body && document.readyState !== 'loading' && looksLikeWipe(v)) {
                console.warn('Blocked body.textContent wipe payload:', JSON.stringify(String(v).slice(0, 60)));
                return;
              }
              return origSetText.call(this, v);
            }
          });
        }

        if (Element.prototype.replaceChildren) {
          var origReplaceChildren = Element.prototype.replaceChildren;
          Element.prototype.replaceChildren = function () {
            if (this === document.body && document.readyState !== 'loading') {
              var allTextOrEmpty = arguments.length === 0 || (
                arguments.length === 1 &&
                (typeof arguments[0] === 'string'
                  ? looksLikeWipe(arguments[0])
                  : (arguments[0] && arguments[0].nodeType === 3 && looksLikeWipe(arguments[0].nodeValue)))
              );
              if (allTextOrEmpty) {
                console.warn('Blocked body.replaceChildren wipe.');
                return;
              }
            }
            return origReplaceChildren.apply(this, arguments);
          };
        }
      })();
    </script>

    {{ content_for_header }}

    <style>
      :root {
        --color-primary: {{ settings.color_primary }};
        --color-secondary: {{ settings.color_secondary }};
        --color-white: #ffffff;
        --color-black: #000000;
        --color-text: {{ settings.color_text }};
        --color-muted: {{ settings.color_muted }};
        --color-border: rgba(0, 0, 0, 0.08);
        --color-surface: rgba(255, 255, 255, 0.88);
        --shadow-soft: 0 20px 40px rgba(0, 0, 0, 0.08);
        --shadow-hover: 0 24px 50px rgba(0, 0, 0, 0.14);
        --radius-card: 28px;
        --radius-pill: 999px;
        --hero-panel-height: clamp(420px, 42vw, 520px);
        --grid-card-min-height: 320px;
        --review-card-min-height: 280px;
        --media-ratio: 4 / 3;
        --content-width: min(1180px, calc(100vw - 40px));
        --section-space: clamp(64px, 9vw, 108px);
        --font-heading: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families }};
        --font-body: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families }};
      }
      body {
        font-family: var(--font-body);
      }
      .section-heading h2,
      .page-hero h1,
      .hero-copy h1,
      .product-purchase-card h1,
      .blog-post-copy h1,
      .cta-banner h2,
      h1,
      h2,
      h3,
      h4 {
        font-family: var(--font-heading);
      }
    </style>

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  </head>
  <body class="template-{{ template.name | handle }}{% if template.suffix %} template-{{ template.suffix | handle }}{% endif %}{% if template.name == 'index' %} home-page{% endif %}" data-cart-count="{{ cart.item_count }}">
    <div id="ThemeRoot" data-theme-root>
      <a class="skip-to-content-link visually-hidden" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>

      {% section 'announcement-bar' %}
      {% section 'header' %}

      <main id="MainContent" class="site-shell" role="main">
        {{ content_for_layout }}
      </main>

      {% section 'footer' %}
      {% render 'cart-drawer' %}
    </div>

    <script>
      window.theme = window.theme || {};
      window.theme.routes = {
        cart: '{{ routes.cart_url }}',
        cartAdd: '{{ routes.cart_add_url }}',
        cartChange: '{{ routes.cart_change_url }}',
        cartUpdate: '{{ routes.cart_update_url }}',
        predictiveSearch: '{{ routes.predictive_search_url }}'
      };
      window.theme.moneyFormat = {{ shop.money_format | json }};
    </script>

    <script>
      (function () {
        function unhidePage() {
          if (!document.body) return;

          document.documentElement.hidden = false;
          document.body.hidden = false;
          document.documentElement.removeAttribute('hidden');
          document.body.removeAttribute('hidden');
          document.body.removeAttribute('aria-hidden');
          document.body.removeAttribute('inert');

          document.documentElement.style.visibility = 'visible';
          document.body.style.visibility = 'visible';
          document.documentElement.style.display = 'block';
          document.body.style.display = 'block';
          document.body.style.opacity = '1';
        }

        document.addEventListener('DOMContentLoaded', unhidePage);
        window.addEventListener('load', unhidePage);
        window.setInterval(unhidePage, 500);
      })();
    </script>

  </body>
</html>
