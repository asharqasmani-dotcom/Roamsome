<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_primary }}">
    <link rel="canonical" href="{{ canonical_url }}">

    {% if settings.favicon != blank %}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 64, height: 64 }}">
    {% endif %}

    {% if settings.heading_font %}
      {{ settings.heading_font | font_face: font_display: 'swap' }}
    {% endif %}
    {% if settings.body_font %}
      {{ settings.body_font | font_face: font_display: 'swap' }}
    {% endif %}

    <title>
      {{ page_title }}
      {% if current_tags %} &ndash; tagged {{ current_tags | join: ', ' }}{% endif %}
      {% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
      {% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    <script>
      (function () {
        window.__ROAMSOME_ALLOW_DOCUMENT_WRITE__ = true;
        window.__ROAMSOME_IS_SHOPIFY_PREVIEW__ = /[?&](preview_theme_id|pb|_fd)=/.test(window.location.search) || !!(window.Shopify && (window.Shopify.designMode || window.Shopify.inspectMode));
        var nativeOpen = document.open ? document.open.bind(document) : null;
        var nativeWrite = document.write.bind(document);
        var nativeWriteln = document.writeln ? document.writeln.bind(document) : null;
        var nativeClose = document.close ? document.close.bind(document) : null;

        function appendLateWrite(html) {
          if (!document.body) return;

          var template = document.createElement('template');
          template.innerHTML = html;

          Array.prototype.slice.call(template.content.querySelectorAll('script')).forEach(function (oldScript) {
            var replacement = document.createElement('script');

            Array.prototype.slice.call(oldScript.attributes).forEach(function (attribute) {
              replacement.setAttribute(attribute.name, attribute.value);
            });

            if (oldScript.textContent) replacement.textContent = oldScript.textContent;
            oldScript.parentNode.replaceChild(replacement, oldScript);
          });

          document.body.appendChild(template.content);
        }

        function safeWrite() {
          var html = Array.prototype.join.call(arguments, '');
          var trimmed = String(html || '').trim();
          var allowNativeWrite = window.__ROAMSOME_ALLOW_DOCUMENT_WRITE__ === true && document.readyState === 'loading';

          if (allowNativeWrite) {
            nativeWrite(html);
            return;
          }

          if (!trimmed || trimmed === '0') {
            console.warn('Blocked late document.write payload:', trimmed);
            return;
          }

          try {
            appendLateWrite(trimmed);
          } catch (error) {
            console.warn('Late document.write interception failed.', error);
          }
        }

        document.write = safeWrite;

        if (nativeOpen) {
          document.open = function () {
            if (window.__ROAMSOME_ALLOW_DOCUMENT_WRITE__ === true && document.readyState === 'loading') {
              return nativeOpen();
            }

            console.warn('Blocked late document.open call.');
            return document;
          };
        }

        if (nativeWriteln) {
          document.writeln = function () {
            var html = Array.prototype.join.call(arguments, '') + '\n';
            safeWrite(html);
          };
        }

        if (nativeClose) {
          document.close = function () {
            if (window.__ROAMSOME_ALLOW_DOCUMENT_WRITE__ === true && document.readyState === 'loading') {
              return nativeClose();
            }

            return document;
          };
        }
      })();
    </script>

    {{ content_for_header }}

    <script>
      window.__ROAMSOME_ALLOW_DOCUMENT_WRITE__ = false;
    </script>

    <style>
      :root {
        --color-primary: {{ settings.color_primary }};
        --color-secondary: {{ settings.color_secondary }};
        --color-white: #ffffff;
        --color-black: #000000;
        --color-text: {{ settings.color_text }};
        --color-muted: {{ settings.color_muted }};
        --color-border: rgba(0, 0, 0, 0.08);
        --color-surface: rgba(255, 255, 255, 0.88);
        --shadow-soft: 0 20px 40px rgba(0, 0, 0, 0.08);
        --shadow-hover: 0 24px 50px rgba(0, 0, 0, 0.14);
        --radius-card: 28px;
        --radius-pill: 999px;
        --hero-panel-height: clamp(420px, 42vw, 520px);
        --grid-card-min-height: 320px;
        --review-card-min-height: 280px;
        --media-ratio: 4 / 3;
        --content-width: min(1180px, calc(100vw - 40px));
        --section-space: clamp(64px, 9vw, 108px);
        --font-heading: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families }};
        --font-body: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families }};
      }
      body {
        font-family: var(--font-body);
      }
      .section-heading h2,
      .page-hero h1,
      .hero-copy h1,
      .product-purchase-card h1,
      .blog-post-copy h1,
      .cta-banner h2,
      h1,
      h2,
      h3,
      h4 {
        font-family: var(--font-heading);
      }
    </style>

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  </head>
  <body class="template-{{ template.name | handle }}{% if template.suffix %} template-{{ template.suffix | handle }}{% endif %}{% if template.name == 'index' %} home-page{% endif %}" data-cart-count="{{ cart.item_count }}">
    <div id="ThemeRoot" data-theme-root>
      <a class="skip-to-content-link visually-hidden" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>

      {% section 'announcement-bar' %}
      {% section 'header' %}

      <main id="MainContent" class="site-shell" role="main">
        {{ content_for_layout }}
      </main>

      {% section 'footer' %}
      {% render 'cart-drawer' %}
    </div>

    <script>
      window.theme = window.theme || {};
      window.theme.routes = {
        cart: '{{ routes.cart_url }}',
        cartAdd: '{{ routes.cart_add_url }}',
        cartChange: '{{ routes.cart_change_url }}',
        cartUpdate: '{{ routes.cart_update_url }}',
        predictiveSearch: '{{ routes.predictive_search_url }}'
      };
      window.theme.moneyFormat = {{ shop.money_format | json }};
    </script>

    <script>
      (function () {
        if (window.__ROAMSOME_IS_SHOPIFY_PREVIEW__) return;

        var snapshot = '';
        var restoring = false;
        var restoreAttempts = 0;
        var maxRestoreAttempts = 3;
        var integrityInterval = null;
        var observedBody = null;
        var observer = new MutationObserver(function () {
          if (bodyLooksCorrupted()) restoreThemeRoot();
        });

        function getRoot() {
          return document.getElementById('ThemeRoot');
        }

        function captureSnapshot() {
          var root = getRoot();
          if (root) snapshot = root.outerHTML;
        }

        function rebindObserver() {
          if (!document.body || observedBody === document.body) return;

          observer.disconnect();
          observer.observe(document.body, { childList: true, subtree: false });
          observedBody = document.body;
        }

        function bodyLooksCorrupted() {
          var root = getRoot();
          var main = document.getElementById('MainContent');

          if (root && main) return false;

          var bodyText = String((document.body && document.body.textContent) || '').trim();
          var bodyChildren = document.body ? document.body.children.length : 0;
          var hasOnlyAppNodes = !!document.getElementById('seal-subs-loaded') || !!document.getElementById('web-pixels-manager-sandbox-container');

          return !main || bodyText === '0' || (hasOnlyAppNodes && bodyChildren <= 3);
        }

        function pruneCorruptedNodes() {
          if (!document.body) return;

          Array.prototype.slice.call(document.body.childNodes).forEach(function (node) {
            if (node.nodeType === Node.TEXT_NODE && String(node.textContent || '').trim() === '0') {
              node.remove();
            }
          });
        }

        function restoreThemeRoot() {
          if (restoring || !snapshot || restoreAttempts >= maxRestoreAttempts || !bodyLooksCorrupted()) return;
          restoring = true;
          restoreAttempts += 1;

          try {
            var mount = document.createElement('div');
            mount.innerHTML = snapshot;
            var restoredRoot = mount.firstElementChild;
            if (!restoredRoot) return;

            pruneCorruptedNodes();

            var currentRoot = getRoot();
            if (currentRoot) currentRoot.remove();
            document.body.insertBefore(restoredRoot, document.body.firstChild);
            captureSnapshot();
            rebindObserver();

            if (typeof window.ROAMSOME_THEME_INIT === 'function') {
              window.ROAMSOME_THEME_INIT();
            }
          } finally {
            restoring = false;
          }
        }

        function scheduleIntegrityCheck(delay) {
          window.setTimeout(function () {
            if (bodyLooksCorrupted()) restoreThemeRoot();
          }, delay);
        }

        function startIntegrityMonitor() {
          if (integrityInterval) return;

          integrityInterval = window.setInterval(function () {
            rebindObserver();

            if (!snapshot) captureSnapshot();
            if (bodyLooksCorrupted()) restoreThemeRoot();
          }, 1000);
        }

        document.addEventListener('DOMContentLoaded', function () {
          captureSnapshot();
          rebindObserver();
          startIntegrityMonitor();
          scheduleIntegrityCheck(1200);
        });

        window.addEventListener('load', function () {
          captureSnapshot();
          rebindObserver();
          startIntegrityMonitor();
          scheduleIntegrityCheck(1500);
        });
      })();
    </script>

  </body>
</html>
