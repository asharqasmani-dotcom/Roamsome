{% assign current_variant = product.selected_or_first_available_variant %}
<section class="page-hero">
  <div class="container">
    <div class="section-heading">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h1>{{ section.settings.heading | default: product.title }}</h1>
      <p>{{ section.settings.text }}</p>
    </div>
    <div class="product-page-stack" data-product-section>
      <div class="product-layout">
        <div class="product-main-column">
          <article class="detail-card product-image-card">
            <div class="product-gallery">
              <div class="product-gallery__main">
                {% if product.featured_media %}
                  {{ product.featured_media | image_url: width: 1600 | image_tag: loading: 'lazy', alt: product.title }}
                {% endif %}
              </div>
              {% if product.media.size > 1 %}
                <div class="product-gallery__thumbs">
                  {% for media in product.media limit: 4 %}
                    {{ media | image_url: width: 300 | image_tag: loading: 'lazy', alt: product.title }}
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </article>
          <div class="product-info-stack">
            <article class="summary-card surprise-story-card">
              <span class="eyebrow">{{ section.settings.story_eyebrow }}</span>
              <h3>{{ section.settings.story_heading }}</h3>
              <p>{{ section.settings.story_text }}</p>
            </article>
            <article class="summary-card">
              <h3>{{ section.settings.includes_heading }}</h3>
              <div class="rte">{{ product.description }}</div>
            </article>
            <article class="summary-card">
              <h3>{{ section.settings.delivery_heading }}</h3>
              <p>{{ section.settings.delivery_text }}</p>
              <div class="mini-points">
                <span class="mini-pill">Tracked UK delivery</span>
                <span class="mini-pill">Chilled packaging</span>
              </div>
            </article>
          </div>
        </div>
        <article class="detail-card product-purchase-card">
          {% if product.vendor != blank %}<div class="kicker">{{ product.vendor }}</div>{% endif %}
          <h1>{{ product.title }}</h1>
          {% if product.metafields.custom.short_description != blank %}
            <p>{{ product.metafields.custom.short_description }}</p>
          {% elsif product.description != blank %}
            <p>{{ product.description | strip_html | truncate: 180 }}</p>
          {% endif %}
          <div class="price">
            <strong data-product-price>{{ current_variant.price | money }}</strong>
            <span data-product-compare{% unless current_variant.compare_at_price > current_variant.price %} hidden{% endunless %}>{% if current_variant.compare_at_price > current_variant.price %}{{ current_variant.compare_at_price | money }}{% endif %}</span>
          </div>
          <div class="tag-list">
            {% if product.metafields.custom.meals_per_week != blank %}<span class="tag">{{ product.metafields.custom.meals_per_week }} meals per week</span>{% endif %}
            {% if product.metafields.custom.servings != blank %}<span class="tag">{{ product.metafields.custom.servings }}</span>{% endif %}
            <span class="tag">Pause or cancel anytime</span>
          </div>
          {% form 'product', product, class: 'js-product-form', data-type: 'add-to-cart-form' %}
            {% if product.variants.size > 1 %}
              <div class="product-form__input">
                <label for="Variant-{{ section.id }}">Variant</label>
                <select id="Variant-{{ section.id }}" name="id" data-variant-select>
                  {% for variant in product.variants %}
                    <option value="{{ variant.id }}" data-price="{{ variant.price | money }}" data-compare-price="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}" {% if variant == current_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>{{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}</option>
                  {% endfor %}
                </select>
              </div>
            {% else %}
              <input type="hidden" name="id" value="{{ current_variant.id }}">
            {% endif %}
            <div class="product-form__input">
              <label for="Quantity-{{ section.id }}">{{ 'products.product.quantity' | t }}</label>
              <input id="Quantity-{{ section.id }}" type="number" name="quantity" min="1" value="1">
            </div>
            {% if product.selling_plan_groups.size > 0 %}
              <div class="product-form__input">
                <label for="SellingPlan-{{ section.id }}">{{ 'products.product.subscribe' | t }}</label>
                <select id="SellingPlan-{{ section.id }}" name="selling_plan">
                  <option value="">One-time purchase</option>
                  {% for group in product.selling_plan_groups %}
                    {% for selling_plan in group.selling_plans %}
                      <option value="{{ selling_plan.id }}">{{ group.name }} - {{ selling_plan.name }}</option>
                    {% endfor %}
                  {% endfor %}
                </select>
              </div>
            {% endif %}
            <div class="product-form__buttons">
              <button class="btn purchase-cta" type="submit" {% unless current_variant.available %}disabled{% endunless %}>{{ 'products.product.add_to_cart' | t }}</button>
            </div>
            {{ form | payment_button }}
          {% endform %}
        </article>
      </div>

      <section class="product-related">
        <div class="section-heading">
          <span class="eyebrow">{{ section.settings.related_eyebrow }}</span>
          <h2>{{ section.settings.related_heading }}</h2>
          <p>{{ section.settings.related_text }}</p>
        </div>
        <div class="plans-grid">
          {% assign related_collection = product.collections.first %}
          {% if related_collection != blank %}
            {% for related_product in related_collection.products limit: 3 %}
              {% if related_product.id != product.id %}
                {% render 'product-card', product: related_product %}
              {% endif %}
            {% endfor %}
          {% endif %}
        </div>
      </section>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Plan detail" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Subscription plan overview" },
    { "type": "textarea", "id": "text", "label": "Intro text", "default": "Review what’s included, delivery details, previous destination examples and flexible subscription benefits before checkout." },
    { "type": "text", "id": "story_eyebrow", "label": "Story eyebrow", "default": "Curated surprise" },
    { "type": "text", "id": "story_heading", "label": "Story heading", "default": "Each week, a new country. No choices. Just discovery." },
    { "type": "textarea", "id": "story_text", "label": "Story text", "default": "Every ROAMSOME box is a fully curated route. We keep the destination secret so the delivery feels like a reveal, not a menu decision." },
    { "type": "text", "id": "includes_heading", "label": "Includes heading", "default": "What’s included" },
    { "type": "text", "id": "delivery_heading", "label": "Delivery heading", "default": "Delivery details" },
    { "type": "textarea", "id": "delivery_text", "label": "Delivery text", "default": "Delivered chilled every Tuesday or Thursday with tracking included across mainland UK." },
    { "type": "text", "id": "related_eyebrow", "label": "Related eyebrow", "default": "Related products" },
    { "type": "text", "id": "related_heading", "label": "Related heading", "default": "You may also like" },
    { "type": "textarea", "id": "related_text", "label": "Related text", "default": "Explore other ROAMSOME subscription plans while you’re here." }
  }
}
{% endschema %}
