<section class="section section-soft">
  <div class="container">
    <article class="upcoming-card">
      <div class="upcoming-card-copy">
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.text }}</p>
        <div class="allergen-grid">
          {% for block in section.blocks %}
            <span class="tag">{{ block.settings.text }}</span>
          {% endfor %}
        </div>
        <p class="upcoming-note">{{ section.settings.note }}</p>
      </div>
      <div class="upcoming-card-visual" aria-hidden="true">
        <img
          class="upcoming-card-image"
          src="{{ 'upcoming-box-info-background.png' | asset_url }}"
          alt=""
          loading="lazy"
        >
      </div>
    </article>
  </div>
</section>

{% schema %}
{
  "name": "Upcoming box info",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Upcoming Box Info" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Upcoming Box Info" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "We keep the next destination secret on purpose. For upcoming deliveries, we only share essential allergen guidance so the experience stays curated and surprising." },
    { "type": "textarea", "id": "note", "label": "Note", "default": "Full destination and meal details are revealed when your box arrives." }
  ],
  "blocks": [
    { "type": "allergen", "name": "Allergen", "settings": [{ "type": "text", "id": "text", "label": "Text", "default": "May include milk" }] }
  ],
  "presets": [{ "name": "Upcoming box info", "blocks": [{ "type": "allergen" }, { "type": "allergen", "settings": { "text": "May include eggs" } }, { "type": "allergen", "settings": { "text": "May include wheat and gluten" } }, { "type": "allergen", "settings": { "text": "May include sesame" } }, { "type": "allergen", "settings": { "text": "Prepared in a kitchen that handles nuts" } }] }]
}
{% endschema %}
