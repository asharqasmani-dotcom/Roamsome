<section class="section section-soft">
  <div class="container">
    <div class="section-heading">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>
    <div class="story-stack">
      {% for block in section.blocks %}
        <article class="story-card">
          {% if block.settings.eyebrow != blank %}<span class="eyebrow">{{ block.settings.eyebrow }}</span>{% endif %}
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Story cards",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated discovery" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Each week, a new country. No choices. Just discovery." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "ROAMSOME is intentionally curated. There is no meal picking or menu building, just a beautifully designed country experience that arrives ready to reveal itself at your table." }
  ],
  "blocks": [
    { "type": "story", "name": "Story card", "settings": [
      { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "A surprise country experience" },
      { "type": "text", "id": "title", "label": "Title", "default": "A surprise country experience" },
      { "type": "textarea", "id": "text", "label": "Text", "default": "Every delivery is built around one destination, with premium ingredients, a recipe journey and cultural cues that make the evening feel transportive from the first step to the final plate." }
    ] }
  ],
  "presets": [{ "name": "Story cards", "blocks": [{ "type": "story" }] }]
}
{% endschema %}
