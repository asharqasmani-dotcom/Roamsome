<section class="section">
  <div class="container">
    {% if section.settings.show_heading %}
      <div class="section-heading">
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.text }}</p>
      </div>
    {% endif %}
    <div class="faq-grid">
      {% for block in section.blocks %}
        <article class="faq-item">
          <h3>{{ block.settings.question }}</h3>
          <p>{{ block.settings.answer }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ grid",
  "settings": [
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Answers for delivery, subscriptions and preferences" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Everything you need to know about how ROAMSOME works before you subscribe or while managing your plan." }
  ],
  "blocks": [
    { "type": "faq", "name": "FAQ", "settings": [
      { "type": "text", "id": "question", "label": "Question", "default": "Where do you deliver?" },
      { "type": "textarea", "id": "answer", "label": "Answer", "default": "Roamsome currently delivers across mainland UK with chilled packaging and tracked delivery slots each week." }
    ] }
  ],
  "presets": [{ "name": "FAQ grid" }]
}
{% endschema %}
