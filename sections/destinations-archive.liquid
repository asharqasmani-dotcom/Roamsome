<section class="section{% if section.settings.soft_background %} section-soft{% endif %}">
  <div class="container">
    <div class="section-heading">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}<p>{{ section.settings.text }}</p>{% endif %}
    </div>
    <div class="menu-grid">
      {% for block in section.blocks %}
        <article class="meal-card">
          {% if block.settings.image != blank %}
            <div class="meal-image" style="background-image:url('{{ block.settings.image | image_url: width: 1200 }}')"></div>
          {% else %}
            <div class="meal-image" style="background:linear-gradient(135deg, rgba(253,113,60,0.14), rgba(246,244,231,0.92));"></div>
          {% endif %}
          <div class="card-body">
            <div class="kicker">{{ block.settings.flag }} {{ block.settings.country }}</div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
            <div class="tag-list">
              {% if block.settings.tag_1 != blank %}<span class="tag">{{ block.settings.tag_1 }}</span>{% endif %}
              {% if block.settings.tag_2 != blank %}<span class="tag">{{ block.settings.tag_2 }}</span>{% endif %}
              {% if block.settings.tag_3 != blank %}<span class="tag">{{ block.settings.tag_3 }}</span>{% endif %}
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Destinations archive",
  "settings": [
    { "type": "checkbox", "id": "soft_background", "label": "Use soft background", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Explore past boxes" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Previous destinations that built the ritual" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "From bright Mediterranean tables to comfort-led city suppers, past ROAMSOME boxes show the kind of premium journeys subscribers have already experienced." }
  ],
  "blocks": [
    {
      "type": "destination",
      "name": "Destination",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "flag", "label": "Flag", "default": "🇮🇹" },
        { "type": "text", "id": "country", "label": "Country", "default": "Italy" },
        { "type": "text", "id": "title", "label": "Title", "default": "Sicily Summer Table" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Bright citrus, basil, roasted vegetables and silky pasta inspired by long warm evenings on the coast." },
        { "type": "text", "id": "tag_1", "label": "Tag 1", "default": "Past box" },
        { "type": "text", "id": "tag_2", "label": "Tag 2", "default": "Fresh herbs" },
        { "type": "text", "id": "tag_3", "label": "Tag 3", "default": "Mediterranean warmth" }
      ]
    }
  ],
  "presets": [{ "name": "Destinations archive" }]
}
{% endschema %}
