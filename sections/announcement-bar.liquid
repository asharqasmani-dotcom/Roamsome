{% if section.settings.show_announcement and section.settings.text != blank %}
  <div class="announcement-bar">
    <div class="container announcement-bar__inner">
      <p>{{ section.settings.text }}</p>
      {% if section.settings.link_text != blank and section.settings.link != blank %}
        <a href="{{ section.settings.link }}">{{ section.settings.link_text }}</a>
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement", "default": true },
    { "type": "text", "id": "text", "label": "Text", "default": "Limited weekly slots available for new subscribers." },
    { "type": "text", "id": "link_text", "label": "Link text", "default": "Explore subscriptions" },
    { "type": "url", "id": "link", "label": "Link" }
  ]
}
{% endschema %}
