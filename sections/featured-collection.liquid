{% assign collection_to_show = collections[section.settings.collection] %}
{% if collection_to_show == blank or collection_to_show.products_count == 0 %}
  {% assign collection_to_show = collections.all %}
{% endif %}
<section class="section{% if section.settings.soft_background %} section-soft{% endif %}">
  <div class="container">
    <div class="section-heading">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>
    {% if collection_to_show != blank and collection_to_show.products_count > 0 %}
      <div class="plans-grid">
        {% for product in collection_to_show.products limit: section.settings.products_to_show %}
          {% render 'product-card', product: product, featured: forloop.first, badge_text: product.metafields.custom.badge %}
        {% endfor %}
      </div>
    {% elsif section.blocks.size > 0 %}
      <div class="plans-grid">
        {% for block in section.blocks limit: section.settings.products_to_show %}
          <article class="plan-card{% if forloop.first %} plan-highlight{% endif %}">
            {% if block.settings.image != blank %}
              <div class="meal-image plan-card-image" style="background-image:url('{{ block.settings.image | image_url: width: 900 }}')"></div>
            {% else %}
              <div class="meal-image plan-card-image" style="background:linear-gradient(135deg, rgba(253,113,60,0.14), rgba(246,244,231,0.92));"></div>
            {% endif %}
            {% if block.settings.badge != blank %}
              <span class="plan-badge">{{ block.settings.badge }}</span>
            {% endif %}
            {% if block.settings.kicker != blank %}
              <div class="kicker">{{ block.settings.kicker }}</div>
            {% endif %}
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
            <div class="price">
              <strong>{{ block.settings.price }}</strong>
              <span>/ week</span>
            </div>
            <div class="inline-actions inline-actions-single">
              <a class="btn" href="{{ block.settings.button_link | default: routes.all_products_collection_url }}">{{ block.settings.button_label }}</a>
            </div>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <article class="summary-card">
        <h3>Select a featured collection</h3>
        <p>Choose a Shopify collection in the theme customizer to display products here automatically.</p>
      </article>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "checkbox", "id": "soft_background", "label": "Use soft background", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Subscription plans" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose the plan that fits your week" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "From a lighter two-meal rhythm to a full five-meal culinary route, every subscription includes flexibility and premium delivery." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 3, "max": 12, "step": 1, "default": 3 }
  ],
  "blocks": [
    {
      "type": "fallback_product",
      "name": "Fallback product",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Most Popular" },
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Best seller across the UK" },
        { "type": "text", "id": "title", "label": "Title", "default": "Voyager Plan" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Our signature subscription with three globally inspired dinners curated as one surprise country journey each week." },
        { "type": "text", "id": "price", "label": "Price", "default": "£42.00" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "View Product" },
        { "type": "url", "id": "button_link", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured collection",
      "blocks": [
        {
          "type": "fallback_product",
          "settings": {
            "badge": "Most Flexible",
            "kicker": "Ideal for first-time subscribers",
            "title": "Explorer Plan",
            "text": "A lighter weekly ritual for curious cooks who want a compact surprise-country experience at home.",
            "price": "£29.00"
          }
        },
        {
          "type": "fallback_product",
          "settings": {
            "badge": "Most Popular",
            "kicker": "Best seller across the UK",
            "title": "Voyager Plan",
            "text": "Our signature subscription with three globally inspired dinners curated as one surprise country journey each week.",
            "price": "£42.00"
          }
        },
        {
          "type": "fallback_product",
          "settings": {
            "badge": "Premium Choice",
            "kicker": "For committed home hosts",
            "title": "Grand Tour Plan",
            "text": "A full week of premium discovery for households who want a richer surprise-country experience with extra hosting energy.",
            "price": "£65.00"
          }
        }
      ]
    }
  ]
}
{% endschema %}
