<section class="page-hero">
  <div class="container">
    <div class="section-heading">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h1>{{ collection.title }}</h1>
      {% if collection.description != blank %}<p class="collection-description">{{ collection.description }}</p>{% endif %}
    </div>

    <div class="collection-toolbar">
      <div class="tag-list">
        <span class="meta-chip">{{ collection.products_count }} products</span>
      </div>
      <form method="get">
        <label class="visually-hidden" for="SortBy">Sort by</label>
        <select id="SortBy" name="sort_by" class="sort-by-select" onchange="this.form.submit()">
          {% for option in collection.sort_options %}
            <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>{{ option.name }}</option>
          {% endfor %}
        </select>
      </form>
    </div>

    {% paginate collection.products by section.settings.products_per_page %}
      <div class="shop-grid">
        {% for product in collection.products %}
          {% render 'product-card', product: product, badge_text: product.metafields.custom.badge %}
        {% else %}
          <article class="summary-card"><p>No products found in this collection yet.</p></article>
        {% endfor %}
      </div>
      {% if paginate.pages > 1 %}
        <div class="pagination-wrapper">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Main collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collection" },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 6, "max": 24, "step": 3, "default": 12 }
  ]
}
{% endschema %}
